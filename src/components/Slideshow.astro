---
export interface Props {
  images: { src: string; alt: string }[];
}
const { images } = Astro.props;
---

<div class="slideshow" id="slideshow01">
  <div class="slideshow-track">
    <div class="slides" id="slides">
      {images.map((img) => (
        <div class="slide">
          <img src={img.src} alt={img.alt} loading="lazy" />
        </div>
      ))}
    </div>
    <button class="arrow prev" id="prev" aria-label="Previous">&#8592;</button>
    <button class="arrow next" id="next" aria-label="Next">&#8594;</button>
  </div>
  <div class="slideshow-nav" id="dots">
    {images.map((_, i) => (
      <button class={`dot${i === 0 ? ' active' : ''}`} data-index={i} aria-label={`Slide ${i + 1}`}></button>
    ))}
  </div>
</div>

<style>
  .slideshow {
    width: 100%;
    max-width: 100%;
  }

  .slideshow-track {
    position: relative;
    width: 75%;
    max-width: 750px;
    margin: 0 auto;
    overflow: hidden;
    border-radius: 12px;
    aspect-ratio: 4/3;
    background: #3b2d21;
  }

  .slides {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.4s ease;
    will-change: transform;
  }

  .slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
  }

  .slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  .arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.6);
    border: none;
    cursor: pointer;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.7;
    transition: opacity 0.2s ease;
    z-index: 10;
  }

  .arrow:hover { opacity: 1; }
  .prev { left: 0.75rem; }
  .next { right: 0.75rem; }

  .slideshow-nav {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #2a2118;
    opacity: 0.25;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.25s ease;
  }

  .dot.active { opacity: 1; }
</style>

<script>
  const track = document.querySelector('.slideshow-track') as HTMLElement;
  const slides = document.getElementById('slides') as HTMLElement;
  const dots = document.querySelectorAll('#dots .dot') as NodeListOf<HTMLButtonElement>;
  const total = dots.length;
  let current = 0;
  let startX = 0;
  let isDragging = false;

  function goTo(n: number) {
    current = (n + total) % total;
    slides.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
  }

  document.getElementById('prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('next')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach(dot => dot.addEventListener('click', () => goTo(Number(dot.dataset.index))));

  // Touch support
  track.addEventListener('touchstart', (e) => {
    startX = e.touches[0].clientX;
    isDragging = true;
  }, { passive: true });

  track.addEventListener('touchend', (e) => {
    if (!isDragging) return;
    isDragging = false;
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
  }, { passive: true });

  track.addEventListener('touchmove', (e) => {
    e.preventDefault();
  }, { passive: false });
</script>