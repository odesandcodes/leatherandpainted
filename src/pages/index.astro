---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Leather and Paint — Handmade Leather Goods NYC"
  description="Handmade leather goods in NYC. Sometimes painted, sometimes not. Wallets, bags, totes and accessories."
  canonicalPath="/">
    <div class="site-wrapper">
    <div class="site-main">
      <div class="inner">

        <!-- ═══ HERO ═══ -->
        <div class="hero-container">
          <div class="hero-inner">
            <div class="hero-col-text">
              <h1 class="text-style-3">Leather and Paint</h1>
              <p class="text-style-2">A hobby that looks like a business. Enjoy.</p>
            </div>
            <div class="hero-col-image">
              <div class="image-frame">
                <img src="/images/image01.jpg" alt="Leather and Paint" />
              </div>
            </div>
          </div>
        </div>

        <!-- ═══ SECTION PREVIEWS ═══ -->
        <div class="home-sections">

          <a href="/gallery" class="home-card">
            <div class="home-card-image" style="background-color:#584533;">
              <img src="/images/gallery03/ea426600.jpg" alt="Gallery" loading="lazy" />
            </div>
            <div class="home-card-body">
              <span class="home-card-label">Gallery</span>
              <p>Process shots, experiments, and finished work from the studio.</p>
            </div>
          </a>

          <a href="/store" class="home-card">
            <div class="home-card-image" style="background-color:#504640;">
              <img src="/images/gallery01/a5320bb8.jpg" alt="Store" loading="lazy" />
            </div>
            <div class="home-card-body">
              <span class="home-card-label">Store</span>
              <p>Ready to ship items. Custom orders always welcome.</p>
            </div>
          </a>

        </div>

        <!-- ═══ TAGLINE BAND ═══ -->
        <div class="home-tagline">
          <p>We handmake leather goods in NYC. Sometimes we paint them, sometimes we don't.</p>
          <a href="/collection" class="btn-ghost">See the Work</a>
        </div>

      </div>
    </div>
  </div>
</Layout>

<style>

:global(.site-wrapper),
:global(.site-main),
:global(.inner),
:global(.hero-container),
:global(.hero-inner) {
  overflow: visible !important;
}

:global(.hero-col-text) {
  margin-left: 0 !important;
  padding-left: 1.5rem !important;
  min-width: 0;
}

  /* ═══ HERO ═══ */
  .hero-container { width: 100%; }

  :global(.hero-inner) {
    display: flex !important;
    flex-wrap: nowrap !important;
    align-items: center;
    overflow: visible;
  }

  :global(.hero-col-text) {
    flex: 0 0 55% !important;
    max-width: 55% !important;
    min-width: 0;
    padding: 2rem 1.5rem 2rem 2.5rem;
    text-align: left;
  }

  :global(.hero-col-image) {
    flex: 0 0 45% !important;
    max-width: 45% !important;
    padding: 1.5rem;
    display: flex;
    align-items: stretch;
  }

  :global(.hero-col-image .image-frame) {
    width: 100% !important;
    aspect-ratio: 1/1 !important;
    border-radius: 12px;
    overflow: hidden;
    background: #3b2d21;
  }

  .hero-col-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
    padding-left: 1rem;
  }

  .text-style-3 {
    font-size: clamp(1.2rem, 2vw, 1.8rem) !important;
    line-height: 1.3;
    word-break: normal;
    white-space: nowrap;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .hero-col-image .image-frame {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 3/4;
    background: #3b2d21;
    width: 100%;
  }

  .hero-col-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ═══ BUTTONS ═══ */
  .btn-ghost {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: #2a2118;
    border: 1.5px solid #2a2118;
    padding: 0.55em 1.2em;
    border-radius: 6px;
    transition: all 0.2s ease;
    display: inline-block;
  }

  .btn-ghost:hover {
    background: #2a2118;
    color: #EAE9F5;
  }

  .btn-buynow {
    border-radius: 6px;
    display: inline-block;
  }

  /* ═══ SECTION PREVIEW CARDS ═══ */
  .home-sections {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .home-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0,0,0,0.07);
    border-radius: 12px;
    overflow: hidden;
    background: rgba(255,255,255,0.35);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .home-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(42,33,24,0.1);
  }

  .home-card-image {
    aspect-ratio: 3/2;
    overflow: hidden;
  }

  .home-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .home-card:hover .home-card-image img {
    transform: scale(1.04);
  }

  .home-card-body {
    padding: 1.1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .home-card-label {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #2a2118;
  }

  .home-card-body p {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 300;
    color: #4a3f35;
    line-height: 1.6;
    margin: 0;
  }

  /* ═══ TAGLINE BAND ═══ */
  .home-tagline {
    margin-top: 3rem;
    padding: 2.5rem 2rem;
    background: rgba(42,33,24,0.05);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .home-tagline p {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 300;
    font-style: italic;
    color: #2a2118;
    max-width: 480px;
    line-height: 1.6;
    margin: 0;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 768px) {
    .hero-inner {
      display: flex !important;
      flex-direction: column !important;
    }
    .hero-col-text {
      width: 100% !important;
      padding: 1.5rem !important;
      text-align: center;
    }
    .hero-col-image {
      width: 100% !important;
      padding: 1.5rem !important;
    }
    .home-sections {
      grid-template-columns: 1fr;
    }
    .home-tagline {
      flex-direction: column;
      text-align: center;
    }
  }
</style>