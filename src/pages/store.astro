---
<!-- Quickview Modal -->
<div class="qv-overlay" id="qv-overlay"></div>
<div class="qv-modal" id="qv-modal">
<button class="qv-close" id="qv-close">&times;</button>  <button class="qv-prev" id="qv-prev">&#8592;</button>
  <button class="qv-next" id="qv-next">&#8594;</button>
  <img src="" alt="" id="qv-img" />
</div>

<Layout
  title="Store - Leather and Paint"
  description="Shop handmade leather goods. Wallets, totes, bags, journals and coasters. Made in NYC."
  canonicalPath="/store"
>
  <div class="site-wrapper">
    <div class="site-main">
      <div class="inner">

        <h2 class="text-style-1">Store</h2>
        <p class="text-style-2 store-intro">
          Every item made by hand. Custom orders welcome -
          <a href="mailto:leatherandpainted@gmail.com">get in touch.</a>
        </p>

        <div class="store-grid">
          {products.map(product => (
            <div class={`store-item${product.sold ? ' sold' : ''}`}>

              <div class="store-item-image" data-current="0">
                <img src={product.images[0]} alt={product.name} loading="lazy" />
                {product.sold && <span class="sold-badge">Sold</span>}
                <div class="img-nav">
                  <button class="img-prev" aria-label="Previous image">&#8592;</button>
                  <div class="img-dots">
                    {product.images.map((src, i) => (
                      <span class={`img-dot${i === 0 ? ' active' : ''}`} data-i={i} data-src={src}></span>
                    ))}
                  </div>
                  <button class="img-next" aria-label="Next image">&#8594;</button>
                </div>
              </div>

              <div class="store-item-body">
                <span class="store-badge">{product.badge}</span>
                <h3 class="store-item-name">{product.name}</h3>
                <p class="store-item-desc">{product.description}</p>
                <ul class="store-item-details">
                  {product.details.map(d => <li>{d}</li>)}
                </ul>
                <div class="store-item-footer">
                  <span class="store-price">${product.price}</span>
                  {!product.sold ? (
                    <form action="https://www.paypal.com/cgi-bin/webscr" method="post" style="margin:0;padding:0;border:none;box-shadow:none;background:none;">
                      <input type="hidden" name="cmd" value="_xclick" />
                      <input type="hidden" name="business" value="2eps2gether@gmail.com" />
                      <input type="hidden" name="item_name" value={product.paypalName} />
                      <input type="hidden" name="currency_code" value="USD" />
                      <input type="hidden" name="amount" value={product.price} />
                      <input type="hidden" name="quantity" value="1" />
                      <input type="hidden" name="return" value="https://leatherandpainted.com" />
                      <input type="hidden" name="cancel_return" value="https://leatherandpainted.com" />
                      <button type="submit" class="btn-buynow">Buy Now</button>
                    </form>
                  ) : (
                    <span class="btn-sold">Sold</span>
                  )}
                </div>
              </div>

            </div>
          ))}
        </div>

      </div>
    </div>
  </div>
</Layout>

<style>
  .store-intro { margin-bottom: 2rem; }
  .store-intro a { color: inherit; }

  .store-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2.5rem;
    margin-top: 2rem;
  }

  .store-item {
    display: flex;
    flex-direction: column;
    background: rgba(255,255,255,0.45);
    border: 1px solid rgba(0,0,0,0.07);
    border-radius: 12px;
    overflow: hidden;
  }

  .store-item.sold { opacity: 0.55; }

  .store-item-image {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .store-item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .store-item:hover .store-item-image img {
    transform: scale(1.03);
  }

  .sold-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: #2a2118;
    color: #EAE9F5;
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.3em 0.7em;
    border-radius: 4px;
  }

  /* Image nav */
  .img-nav {
    position: absolute;
    bottom: 0.5rem;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    z-index: 2;
  }

  .img-prev, .img-next {
    background: rgba(255,255,255,0.6);
    border: none;
    cursor: pointer;
    width: 1.8rem;
    height: 1.8rem;
    border-radius: 50%;
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .img-prev:hover, .img-next:hover { opacity: 1; }

  .img-dots {
    display: flex;
    gap: 0.3rem;
  }

  .img-dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: white;
    opacity: 0.5;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .img-dot.active { opacity: 1; }

  .store-item-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.5rem;
  }

  .store-badge {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #7a6a5a;
  }

  .store-item-name {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #2a2118;
    margin: 0;
  }

  .store-item-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 300;
    color: #4a3f35;
    line-height: 1.6;
    margin: 0;
    text-align: left;
  }

  .store-item-details {
    list-style: disc;
    padding-left: 1.1rem;
    margin: 0;
    text-align: left;
  }

  .store-item-details li {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 300;
    color: #6a5a4a;
    line-height: 1.7;
    text-align: left;
  }

  .store-item-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 1rem;
  }

  .store-price {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #2a2118;
  }

  .btn-buynow {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: #EAE9F5;
    background: #2a2118;
    padding: 0.55em 1.2em;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .btn-buynow:hover { background: #3d3025; }

  .btn-sold {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #9a8a7a;
  }

.qv-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.7);
  z-index: 500;
}
.qv-overlay.open { display: block; }

.qv-modal {
  display: none;
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: min(80vw, 700px);
  aspect-ratio: 4/3;
  z-index: 501;
  border-radius: 12px;
  overflow: hidden;
  background: #2a2118;
}
.qv-modal.open { display: block; }

.qv-modal img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.qv-close {
  position: absolute;
  top: 0.75rem;
  right: 0.75rem;
  background: rgba(255,255,255,0.8);
  border: none;
  cursor: pointer;
  width: 2rem;
  height: 2rem;
  border-radius: 50%;
  font-size: 1rem;
  z-index: 10;
}

.qv-prev, .qv-next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255,255,255,0.6);
  border: none;
  cursor: pointer;
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 50%;
  font-size: 1.2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}
.qv-prev { left: 0.75rem; }
.qv-next { right: 0.75rem; }

.store-item-image:has(.img-dot:only-child) .img-nav {
  display: none;
}

  @media (max-width: 600px) {
    .store-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Image carousel
  document.querySelectorAll('.store-item-image').forEach(container => {
    const img = container.querySelector('img') as HTMLImageElement;
    const dots = container.querySelectorAll('.img-dot') as NodeListOf<HTMLElement>;
    const prevBtn = container.querySelector('.img-prev');
    const nextBtn = container.querySelector('.img-next');
    const srcs = dots.length
      ? Array.from(dots).map(d => d.dataset.src || img.src)
      : [img.src];
    let current = 0;
    const total = srcs.length;

    function goTo(n: number) {
      current = (n + total) % total;
      img.src = srcs[current];
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
    }

    prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); goTo(current - 1); });
    nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); goTo(current + 1); });
    dots.forEach((dot, i) => dot.addEventListener('click', (e) => { e.stopPropagation(); goTo(i); }));
    img.addEventListener('click', () => openQV(srcs, current));
  });

  // Quickview
  const overlay = document.getElementById('qv-overlay')!;
  const modal = document.getElementById('qv-modal')!;
  const qvImg = document.getElementById('qv-img') as HTMLImageElement;
  const qvClose = document.getElementById('qv-close')!;
  const qvPrev = document.getElementById('qv-prev')!;
  const qvNext = document.getElementById('qv-next')!;

  let qvSrcs: string[] = [];
  let qvCurrent = 0;

  function openQV(srcs: string[], index: number) {
    qvSrcs = srcs;
    qvCurrent = index;
    qvImg.src = srcs[index];
    modal.classList.add('open');
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
    qvPrev.style.display = srcs.length > 1 ? 'flex' : 'none';
    qvNext.style.display = srcs.length > 1 ? 'flex' : 'none';
  }

  function closeQV() {
    modal.classList.remove('open');
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  function qvGoTo(n: number) {
    qvCurrent = (n + qvSrcs.length) % qvSrcs.length;
    qvImg.src = qvSrcs[qvCurrent];
  }

  qvClose.addEventListener('click', closeQV);
  overlay.addEventListener('click', closeQV);
  qvPrev.addEventListener('click', () => qvGoTo(qvCurrent - 1));
  qvNext.addEventListener('click', () => qvGoTo(qvCurrent + 1));

  document.addEventListener('keydown', (e) => {
    if (!modal.classList.contains('open')) return;
    if (e.key === 'Escape') closeQV();
    if (e.key === 'ArrowRight') qvGoTo(qvCurrent + 1);
    if (e.key === 'ArrowLeft') qvGoTo(qvCurrent - 1);
  });
</script>