---
import Layout from '../layouts/Layout.astro';

const products = [
  {
    image: '/images/store/leather_06.jpg',
    badge: 'Hand stitched',
    name: 'Cross Body Tote',
    paypalName: 'Cross Body Tote - Leather and Paint',
    description: 'Dark chocolate brown cross body tote with embroidered adjustable shoulder strap.',
    details: ['Dark brown — 10 inches tall', '9 inches wide approximately'],
    price: '79',
    sold: false,
  },
  {
    image: '/images/store/leather_04.jpg',
    badge: 'Hand stitched',
    name: 'Painted Carry Tote',
    paypalName: 'Painted Carry Tote - Leather and Paint',
    description: 'Hand painted tote with silver, gold and blue accents. Original painting.',
    details: ['Original painting', 'Approximately 15" wide and 14" tall'],
    price: '59',
    sold: false,
  },
  {
    image: '/images/store/leather_14.jpg',
    badge: 'Hand stitched',
    name: 'Classic Black Tote',
    paypalName: 'Classic Black Tote - Leather and Paint',
    description: 'A classic black tote — veg tanned leather with leather straps. Hand buffed.',
    details: ['Approximately 15" x 14"', 'Approximate 9 inch drop'],
    price: '59',
    sold: false,
  },
  {
    image: '/images/store/leather_15.jpg',
    badge: 'Hand stitched',
    name: 'Classic Brown Tote',
    paypalName: 'Classic Brown Tote - Leather and Paint',
    description: 'Classic brown pull-up leather tote. Gets better with age.',
    details: ['Brown pull up leather', 'Approximately 14" x 15", 9 inch drop'],
    price: '59',
    sold: false,
  },
  {
    image: '/images/store/leather_08.jpg',
    badge: 'Hand painted',
    name: 'Painted Handbag',
    paypalName: 'Painted Handbag - Leather and Paint',
    description: 'Special hand painted handbag — entirely done by us with care and detail.',
    details: ['Approximately 9 x 8 x 5 inches', 'Unlined'],
    price: '119',
    sold: false,
  },
  {
    image: '/images/store/leather_16.jpg',
    badge: 'Hand stitched',
    name: 'Cross Body Tote with Flap',
    paypalName: 'Cross Body Tote with Flap - Leather and Paint',
    description: 'Medium sized cross body tote with flap and clasp closure.',
    details: ['Approximately 15" x 15"', 'Adjustable strap'],
    price: '69',
    sold: false,
  },
  {
    image: '/images/store/leather_18.jpg',
    badge: 'Hand dyed',
    name: 'Leather Journal Cover & Journal',
    paypalName: 'Leather Journal Cover and Journal - Leather and Paint',
    description: 'Large journal cover with elastic keeper. Hand dyed and buffed. Journal included.',
    details: ['Approximately 4 x 5"', 'Veg tanned leather'],
    price: '35',
    sold: false,
  },
  {
    image: '/images/store/leather_19.jpg',
    badge: 'Hand dyed',
    name: 'Leather Journal Cover',
    paypalName: 'Leather Journal Cover - Leather and Paint',
    description: 'Medium journal cover. Veg tanned leather, hand dyed and buffed. Journal included.',
    details: ['Approximately 4 x 5"', 'Beautiful veg tanned leather'],
    price: '30',
    sold: false,
  },
  {
    image: '/images/store/leather_24.jpg',
    badge: 'Hand formed',
    name: 'Leather Desk Valet',
    paypalName: 'Leather Desk Valet - Leather and Paint',
    description: 'Wet formed from extra thick 11-13oz cowhide. Hand formed and sturdy.',
    details: ['Approximately 8" x 8"', 'Extra thick cowhide'],
    price: '22',
    sold: false,
  },
  {
    image: '/images/store/hero_coasters.jpg',
    badge: 'Hand painted',
    name: 'Hand Painted Coaster Set',
    paypalName: 'Hand Painted Coaster Set - Leather and Paint',
    description: 'Set of 4 hand cut and hand painted coasters. Original one-off item.',
    details: ['4 coasters — 4x4 inches each', 'Original one-off item'],
    price: '39',
    sold: false,
  },
  {
    image: '/images/store/leather_33.jpg',
    badge: 'Hand cut',
    name: 'Hand Cut Coasters',
    paypalName: 'Hand Cut Coasters - Leather and Paint',
    description: 'Cut from 8-10oz veg tanned leather. Will take on a beautiful patina with use.',
    details: ['4 x 4 inches', 'Beautiful veg tanned leather'],
    price: '15',
    sold: false,
  },
];
---
<Layout
  title="Store — Leather and Paint"
  description="Shop handmade leather goods. Wallets, totes, bags, journals and coasters. Made in NYC."
  canonicalPath="/store">  
  <div class="site-wrapper">
    <div class="site-main">
      <div class="inner">

        <h2 class="text-style-1">Store</h2>
        <p class="text-style-2 store-intro">
          Every item made by hand. Custom orders welcome —
          <a href="mailto:leatherandpainted@gmail.com">get in touch.</a>
        </p>

        <div class="store-grid">
          {products.map(product => (
            <div class={`store-item${product.sold ? ' sold' : ''}`}>
              <div class="store-item-image">
                <img src={product.image} alt={product.name} loading="lazy" />
                {product.sold && <span class="sold-badge">Sold</span>}
              </div>
              <div class="store-item-body">
                <span class="store-badge">{product.badge}</span>
                <h3 class="store-item-name">{product.name}</h3>
                <p class="store-item-desc">{product.description}</p>
                <ul class="store-item-details">
                  {product.details.map(d => <li>{d}</li>)}
                </ul>
                <div class="store-item-footer">
                  <span class="store-price">${product.price}</span>
              {!product.sold ? (
                  <form action="https://www.paypal.com/cgi-bin/webscr" method="post" style="margin:0;padding:0;border:none;box-shadow:none;background:none;">
                    <input type="hidden" name="cmd" value="_xclick" />
                    <input type="hidden" name="business" value="2eps2gether@gmail.com" />
                    <input type="hidden" name="item_name" value={product.paypalName} />
                    <input type="hidden" name="currency_code" value="USD" />
                    <input type="hidden" name="amount" value={product.price} />
                    <input type="hidden" name="quantity" value="1" />
                    <input type="hidden" name="return" value="https://leatherandpainted.com" />
                    <input type="hidden" name="cancel_return" value="https://leatherandpainted.com" />
                    <button type="submit" class="btn-buynow">Buy Now</button>
                  </form>
                ) : (
                  <span class="btn-sold">Sold</span>
                )}
                </div>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </div>
</Layout>

<style>
  .store-intro { margin-bottom: 2rem; }
  .store-intro a { color: inherit; }

  .store-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2.5rem;
    margin-top: 2rem;
  }

  .store-item {
    display: flex;
    flex-direction: column;
    background: rgba(255,255,255,0.45);
    border: 1px solid rgba(0,0,0,0.07);
    border-radius: 4px;
    overflow: hidden;
  }

  .store-item.sold { opacity: 0.55; }

  .store-item-image {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .store-item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .store-item:hover .store-item-image img {
    transform: scale(1.03);
  }

  .sold-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: #2a2118;
    color: #EAE9F5;
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.3em 0.7em;
    border-radius: 6px;
  }

  .store-item-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.5rem;
  }

  .store-badge {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #7a6a5a;
  }

  .store-item-name {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #2a2118;
    margin: 0;
  }

  .store-item-desc {
    text-align: left;
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 300;
    color: #4a3f35;
    line-height: 1.6;
    margin: 0;
  }

  .store-item-details {
    text-align: left;
    list-style: disc;
    padding-left: 1.1rem;
    margin: 0;
  }

  .store-item-details li {
    text-align: left;
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 300;
    color: #6a5a4a;
    line-height: 1.7;
  }

  .store-item-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 1rem;
  }

  .store-price {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #2a2118;
  }

  .btn-buynow {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: #EAE9F5;
    background: #2a2118;
    padding: 0.55em 1.2em;
    border-radius: 6px;
    transition: background 0.2s ease;
  }

  .btn-buynow:hover { background: #3d3025; }

  .btn-sold {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #9a8a7a;
  }

  @media (max-width: 600px) {
    .store-grid { grid-template-columns: 1fr; }
  }
</style>