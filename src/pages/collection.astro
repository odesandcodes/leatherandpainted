---
import Layout from '../layouts/Layout.astro';
const paypalUrl = 'https://www.paypal.com/paypalme/leatherandpainted';
---
<Layout
  title="Collection — Leather and Paint"
  description="Handmade leather wallets, bags, totes and accessories. Made in NYC."
  canonicalPath="/collection">  
  <div class="site-wrapper">
    <div class="site-main">
      <div class="inner">
        <h2 class="text-style-1">Collection</h2>

        <div class="gallery gallery-wide">
          <div class="inner">
            <ul>
              <li>
                <span class="thumbnail">
                  <span class="frame">
                    <img src="/images/gallery01/4ba711d5.jpg" alt="Wallets" loading="lazy" />
                  </span>
                </span>
                <div class="caption"><p>Wallets</p></div>
              </li>
              <li>
                <span class="thumbnail">
                  <span class="frame">
                    <img src="/images/gallery01/a5320bb8.jpg" alt="Bags" loading="lazy" />
                  </span>
                </span>
                <div class="caption"><p>Bags</p></div>
              </li>
            </ul>
          </div>
        </div>

        <div class="gallery gallery-wide">
          <div class="inner">
            <ul>
              <li>
                <span class="thumbnail">
                  <span class="frame">
                    <img src="/images/gallery02/85b393b1.jpg" alt="Totes" loading="lazy" />
                  </span>
                </span>
                <div class="caption"><p>Totes</p></div>
              </li>
              <li>
                <span class="thumbnail">
                  <span class="frame">
                    <img src="/images/gallery02/1a51a31c.jpg" alt="Accessories" loading="lazy" />
                  </span>
                </span>
                <div class="caption"><p>Accessories</p></div>
              </li>
            </ul>
          </div>
        </div>

        <div class="button-row">
          <a href={paypalUrl} target="_blank" rel="noopener" class="btn-buynow">Buy Now</a>
        </div>

      </div>
    </div>
  </div>
</Layout>